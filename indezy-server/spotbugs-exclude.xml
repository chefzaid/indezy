<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        MapStruct generates the *MapperImpl classes. Their defensive null checks on
        collections that our entities/DTOs never return null (custom getters return
        a fresh list) are emitted by the processor, not authored here, so SpotBugs
        findings in them are not actionable.
    -->
    <Match>
        <Class name="~.*\.mapper\..*MapperImpl"/>
    </Match>

    <!--
        Spring Security's HttpSecurity.build() declares `throws Exception`, so the
        SecurityFilterChain bean must propagate it. The generic throws clause is
        mandated by the framework API and cannot be narrowed.
    -->
    <Match>
        <Class name="dev.swirlit.indezy.config.SecurityConfig"/>
        <Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION"/>
    </Match>
</FindBugsFilter>
